{
  "expo": {
    "name": "CarpioFit",
    "slug": "CarpioFit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/CarpioFitLogo.png",
    "scheme": "carpiofit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/CarpioFitLogo.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.CarpioFit"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/CarpioFitLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a",
          "dark": {
            "backgroundColor": "#0a0a0a"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1114ddf9-3468-4fc7-81c5-8d28e19c9f78"
      }
    }
  }
}